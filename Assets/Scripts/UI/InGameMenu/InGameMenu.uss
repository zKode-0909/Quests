.menuDisplay{
	height: 50%;
	width: 50%;
	background-color: black;
	position: absolute;
	top: 25%;
	left: 25%;
	justify-content: center;
	align-items: center;

}

.buttonsHolder{
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;

	height: 95%;
	width: 95%;

	border-width: 2px;
    border-color: white;
}

.menuButton{
	height: 15%;
	width: 65%;

	border-width: 2px;
	border-color: white;

	color: white;
}